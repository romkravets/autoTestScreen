# ── Anthropic Claude (за замовчуванням) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Groq (безкоштовно, реєстрація на console.groq.com) ───────────────────────
GROQ_API_KEY=gsk_...

# ── OpenRouter (безкоштовні моделі доступні без оплати) ──────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── Локальні моделі (необов'язково, змінити якщо нестандартний порт) ─────────
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ── Кастомний OpenAI-сумісний ендпоінт ───────────────────────────────────────
# CUSTOM_API_BASE=https://your-api.com/v1
# CUSTOM_API_KEY=your-key

# ── Налаштування за замовчуванням ─────────────────────────────────────────────
DEFAULT_QUESTION_COUNT=22
